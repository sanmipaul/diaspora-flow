# Agent wallet private key (the wallet that is registered with ERC-8004 + Self Agent ID)
# Generate a fresh wallet: cast wallet new
# Fund it with ~0.05 CELO on mainnet for gas
AGENT_PRIVATE_KEY=your_agent_private_key_here

# Pinata JWT for IPFS upload (used by register-8004.ts)
# Get one free at https://pinata.cloud
PINATA_JWT=your_pinata_jwt_here

# ERC-8004 agent ID (set this AFTER running: npm run register:8004)
AGENT_8004_ID=
